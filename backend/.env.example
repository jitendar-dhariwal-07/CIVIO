# ── CitizenAI Backend Configuration ──────────────────────────────────
# Copy this file to .env and fill in the values.

# Application
APP_NAME=CitizenAI
DEBUG=true
ENV=development

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/citizenai

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# JWT
JWT_SECRET=change-me-to-a-very-long-random-string-at-least-32-chars

# Frontend
FRONTEND_URL=http://localhost:3000
